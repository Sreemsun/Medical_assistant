# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/medical_assistance

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Email Configuration (for email verification)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM=MedAssist <noreply@medassist.com>

# Client URL (for CORS and email links)
CLIENT_URL=http://localhost:3000

# Optional: absolute path to Python executable used for ML predictions
# Example (Windows): PYTHON_EXECUTABLE=C:/Users/yourname/AppData/Local/Programs/Python/Python313/python.exe
# Example (Render/Linux): PYTHON_EXECUTABLE=python3
PYTHON_EXECUTABLE=

# Encryption key for sensitive data
ENCRYPTION_KEY=your_32_character_encryption_key_here
